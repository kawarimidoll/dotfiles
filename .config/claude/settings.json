{
  "env": {
    "EDITOR": "nvim -n +'set awa' +'startinsert'",
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(* .env*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.ssh/*)",
      "Bash(chmod 777:*)",
      "Bash(curl *)",
      "Bash(do)",
      "Bash(find * -delete*)",
      "Bash(for)",
      "Bash(gh repo delete:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc *)",
      "Bash(nc:*)",
      "Bash(ncat *)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(psql:*)",
      "Bash(push:*)",
      "Bash(pushf:*)",
      "Bash(rmdir *)",
      "Bash(rsync * --delete*)",
      "Bash(scp *)",
      "Bash(security *)",
      "Bash(shred *)",
      "Bash(ssh *)",
      "Bash(su *)",
      "Bash(sudo *)",
      "Bash(sudo:*)",
      "Bash(telnet *)",
      "Bash(unlink *)",
      "Bash(wget *)",
      "Bash(wget:*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(/secrets/**)",
      "Read(**/*.env*)",
      "Read(**/*key)",
      "Read(**/*secrets*)",
      "Read(**/*token*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(/secrets/**)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Write(**/*.env*)",
      "Write(**/*key)",
      "Write(**/*secrets*)",
      "Write(**/*token*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(/secrets/**)",
      "Write(id_ed25519)",
      "Write(id_rsa)",
      "mcp__supabase__execute_sql"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git config:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git switch:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "guard-and-guide"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.nix-profile/libexec/rtk/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/.config/claude/hooks/notification.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/.config/claude/statusline.ts"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "showTurnDuration": true,
  "skipDangerousModePermissionPrompt": true
}
